services:
  {{ service_name }}:
    build:
      context: .
      dockerfile: Dockerfile
    restart: unless-stopped
    environment:
      PORT: ${PORT:-3000}
      APP_HOSTNAME: ${APP_HOSTNAME:-{{ hostname }}}
      NODE_ENV: ${NODE_ENV:-production}
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ docker_network }}
      - traefik.http.routers.{{ safe_name }}.rule=Host(`{{ hostname }}`)
      - traefik.http.routers.{{ safe_name }}.entrypoints=web
      - traefik.http.services.{{ safe_name }}.loadbalancer.server.port=3000
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
