services:
  {{ service_name }}:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - type: bind
        source: {{ source_path }}
        target: /usr/share/nginx/html
        read_only: true
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ docker_network }}
      - traefik.http.routers.{{ safe_name }}.rule={{ traefik_host_rule }}
      - traefik.http.routers.{{ safe_name }}.entrypoints=web
      - traefik.http.services.{{ safe_name }}.loadbalancer.server.port=80
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
