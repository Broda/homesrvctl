services:
  {{ service_name }}:
    build:
      context: .
      dockerfile: Dockerfile
    restart: unless-stopped
    environment:
      PORT: ${PORT:-8000}
      APP_HOSTNAME: ${APP_HOSTNAME:-{{ hostname }}}
      PYTHONUNBUFFERED: 1
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1:${PORT:-8000}/healthz >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ docker_network }}
      - traefik.http.routers.{{ safe_name }}.rule=Host(`{{ hostname }}`)
      - traefik.http.routers.{{ safe_name }}.entrypoints=web
      - traefik.http.services.{{ safe_name }}.loadbalancer.server.port=8000
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
