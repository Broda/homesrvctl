services:
  {{ service_name }}:
    image: nginx:alpine
    restart: unless-stopped
    volumes:
      - ./html:/usr/share/nginx/html:ro
    healthcheck:
      test: ["CMD-SHELL", "wget -qO- http://127.0.0.1/ >/dev/null || exit 1"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 10s
    labels:
      - traefik.enable=true
      - traefik.docker.network={{ docker_network }}
      - traefik.http.routers.{{ safe_name }}.rule=Host(`{{ hostname }}`)
      - traefik.http.routers.{{ safe_name }}.entrypoints=web
      - traefik.http.services.{{ safe_name }}.loadbalancer.server.port=80
    networks:
      - {{ docker_network }}

networks:
  {{ docker_network }}:
    external: true
